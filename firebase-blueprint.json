{
  "entities": {
    "Gig": {
      "title": "Gig",
      "description": "A job offer or gig posted by a user.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the gig." },
        "category": { "type": "string", "description": "Category of the gig." },
        "price": { "type": "string", "description": "Price or rate for the gig." },
        "location": { "type": "string", "description": "Location of the gig." },
        "author": { "type": "string", "description": "Name of the author." },
        "authorId": { "type": "string", "description": "UID of the author." },
        "description": { "type": "string", "description": "Detailed description of the gig." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Time when the gig was created." }
      },
      "required": ["title", "category", "price", "location", "author", "authorId", "description", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["displayName", "email"]
    }
  },
  "firestore": {
    "/gigs/{gigId}": {
      "schema": "Gig",
      "description": "Collection of all gigs."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    }
  }
}
